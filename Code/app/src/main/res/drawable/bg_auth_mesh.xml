<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#FFF3E8FF"
                android:startColor="#FFE0F2FE" />
        </shape>
    </item>
    <item android:left="-60dp" android:top="-30dp">
        <shape android:shape="oval">
            <solid android:color="#66C4B5FD" />
            <size android:width="320dp" android:height="220dp" />
        </shape>
    </item>
    <item android:right="-50dp" android:bottom="80dp">
        <shape android:shape="oval">
            <solid android:color="#66A7F3D0" />
            <size android:width="260dp" android:height="200dp" />
        </shape>
    </item>
</layer-list>
